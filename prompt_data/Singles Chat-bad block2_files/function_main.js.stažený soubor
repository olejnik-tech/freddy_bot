	const baseHeight = winHeight - menuFooter - headHeight;
	const floatBox = baseHeight;
	const chatBodyHeight = baseHeight - topChatHeight - chatToping;
	const rightHeight = baseHeight - rightPanelBar;
	const leftHeight = baseHeight - leftPanelBar;

	$('.chatheight, .pheight').css('height', baseHeight);
