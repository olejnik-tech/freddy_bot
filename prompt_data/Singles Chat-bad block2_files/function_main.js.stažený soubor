clearChat = (data) => {
	if (fload == 1) {
		for (let i = 0; i < data.length; i++) {
			if (data[i].log_type === 'system__clear') {
				$("#show_chat ul").html('');
				clearPlay();
				return true;
			}
		}
	}
	return false;
};

