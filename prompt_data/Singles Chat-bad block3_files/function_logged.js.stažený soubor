$(document).ready(function(){
	systemLoad();
	setTimeout(cleanData, 5000)
	var runClean = setInterval(cleanData, 300000);

	$(document).on('click', '.get_info', function(){
		var profile = $(this).attr('data');
		getProfile(profile);
	});
	$(document).on('click', '.get_finfo', function(){
		var profile = $(this).attr('data');
		getProfile(profile);
	});
	$(document).on('click', '.open_profile', function(){
		editProfile();
	});
	$(document).on('click', '.get_actions', function(){
		var id = $(this).attr('data');
		getActions(id);
	});
	$(document).on('click', '.open_same_page', function(){
		var l = $(this).attr('data');
		openSamePage(l);
	});
	$(document).on('click', '.open_link_page', function(){
		var l = $(this).attr('data');
		openLinkPage(l);
	});
	$(document).on('click', '.get_room_actions', function(){
		var id = $(this).attr('data');
		getRoomActions(id);
	});
	$(document).on('click', '.name_choice, .choice', function() {	
		var curColor = $(this).attr('data');
		if($('#color_form').attr('data-color') == curColor){
			$('.bccheck').replaceWith("");
			$('#color_form').attr('data-color', 'user');
		}
		else {
			$('.bccheck').replaceWith("");
			$(this).append('<i class="fa fa-check bccheck"></i>');
			$('#color_form').attr('data-color', curColor);
		}
		previewName();
	});
	$(document).on('click', '.user_choice', function() {	
		var curColor = $(this).attr('data');
		if($('#tcolor_form').attr('data-color') == curColor){
			$('.bccheck').replaceWith("");
			$('#tcolor_form').attr('data-color', '');
		}
		else {
			$('.bccheck').replaceWith("");
			$(this).append('<i class="fa fa-check bccheck"></i>');
			$('#tcolor_form').attr('data-color', curColor);
		}
		previewText();
	});
	$(document).on('change', '#fontitname', function(){		
		previewName();
	});
	$(document).on('keydown', function(event) {
		if( event.which === 8 && event.ctrlKey && event.altKey ) {
			getConsole();
		}
	});
	$(document).on('click', '#gift_delete', function(){
		$.post('system/box/gift_delete.php', { 
			id: $('#view_gift_id').attr('data') 
		});
	});
	$(document).on('click', '.open_gift', function(){
		$.post('system/box/open_gift.php', { 
			open_gift: $(this).attr('data')
		});
	});
	$(document).on('click', '.view_gift', function(){
		const item = $(this);
		const template = $('#view_gift_template');
		template.find('#view_gift_title').text(item.attr('data-title'));
		template.find('#view_gift_img').attr('src', item.attr('data-img'));
		template.find('#view_gift_id').attr('data', item.attr('data-gift'));
		topModal(template.html(), 300);
	});
	$(document).on('click', '.select_gift', function(){
		const item = $(this);
		const template = $('#gift_confirm_template');
		const method = parseInt(item.attr('data-method'));
		template.find('.gift_selected').attr('src', item.attr('data-img'));
		template.find('.gift_title').text(item.attr('data-title'));
		template.find('.gift_pricing').text(item.attr('data-price'));
		template.find('.gift_sgold, .gift_sruby').hide();
		if(method == 1){
			template.find('.gift_sgold').show();
		}
		else if(method == 2){
			template.find('.gift_sruby').show();
		}
		template.find('.gift_send_btn')
			.attr('data-id', item.attr('data-id'))
			.attr('data-target', item.attr('data-target'));
		topModal(template.html(), 360);
	});
	$(document).on('click', '.view_friend', function(){
		$('#view_friend_name').text($(this).attr('data-name'));
		$('#view_friend_avatar').attr('src', $(this).attr('data-avatar'));
		$('#view_friend_id').attr('data', $(this).attr('data-id'));
		overModal($('#view_friend_template').html());
	});
});