	$.post('system/action/logout.php', { acu_logout: 1 });
}
boomSound = function(snd){
	if(uSound.match(snd)){ return true; }
}
isStaff = function(urank){
	if(urank >= 70){ return true; }
}
betterRank = function(urank){
	if(user_rank > urank){ return true; }
}
