{
  "nickname": "Freddy_922",
  "cdp_url": "http://127.0.0.1:9222",
  "target_url_contains": "chat-avenue.com",
  "poll_interval_seconds": 1.0,
  "output_jsonl": "captures/prompts.jsonl",
  "message_selectors": [
    ".chat_message",
    ".chat-msg",
    ".message",
    ".chat_log .chat_message",
    ".chat_logs .chat_message",
    "#chat_logs .chat_message",
    "[data-message-id]",
    "[class*='chat'][class*='message']",
    "[class*='message']"
  ],
  "history_jsonl": "captures/history.jsonl",
  "latest_prompt_json": "captures/latest_prompt.json",
  "reply_inbox": "captures/next_reply.txt",
  "chat_context_jsonl": "captures/chat_context.jsonl",
  "user_memory_dir": "captures/users",
  "last_codex_prompt_file": "captures/last_codex_prompt.txt",
  "log_file": "captures/runtime.log",
  "brave_script": "scripts/start_brave_debug.ps1",
  "personality_file": "persona_freddy.md",
  "codex_command": [
    "codex",
    "exec",
    "--ephemeral",
    "--sandbox",
    "read-only"
  ],
  "codex_timeout_seconds": 90,
  "ai_history_context_lines": 12,
  "recent_chat_context_lines": 30,
  "input_selectors": [
    "#content",
    "#message",
    "#message_content",
    "#chat_message",
    "#chat_input",
    "#private_content",
    "#post_message",
    "textarea[name='content']",
    "textarea[name='message']",
    "textarea[id*='message']",
    "textarea[id*='content']",
    "input[name='content']",
    "input[name='message']",
    "input[id*='message']",
    "input[id*='content']",
    "[contenteditable='true']",
    "textarea",
    "input[type='text']"
  ],
  "send_button_selectors": [
    "#submit_button",
    "#send_message",
    ".send_message",
    ".chat_send",
    "button[type='submit']",
    "[class*='send']"
  ],
  "send_with_enter": true,
  "confirm_codex_replies": false,
  "ignore_own_timestamped_messages": true,
  "ignore_recent_sent_replies": 20
}
